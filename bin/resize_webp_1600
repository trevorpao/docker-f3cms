#!/usr/bin/env bash
#
# 用途：對指定資料夾中的原始 webp 大圖批次做「保留原圖 + 產生 1600 寬縮圖」。
# 例：./bin/resize_webp_1600 ./www/upload/img/2019/09
#
# 行為摘要：
# - 只接受一個資料夾參數
# - 掃描目標資料夾下兩層內的 webp 檔
# - 只處理檔名主體不含底線的原始檔
# - 只處理寬度大於 1600 的大圖
# - 先把原圖改名成 {原檔名}_ori.webp
# - 再以原檔名產生一張寬度 1600、維持原比例的縮圖

set -euo pipefail

CU_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${ENV_FILE:-$CU_DIR/../.env}"
TARGET_WIDTH="${TARGET_WIDTH:-1600}"

if command -v magick >/dev/null 2>&1; then
  IM_IDENTIFY=(magick identify)
  IM_CONVERT=(magick)
else
  IM_IDENTIFY=(identify)
  IM_CONVERT=(convert)
fi

if [[ ! -f "$ENV_FILE" ]]; then
  echo "UNCERTAIN: Missing .env file: $ENV_FILE"
  exit 1
fi

if ! [[ "$TARGET_WIDTH" =~ ^[0-9]+$ ]]; then
  echo "UNCERTAIN: TARGET_WIDTH must be an integer"
  exit 1
fi

set -a
. "$ENV_FILE"
set +a

resolve_target_dir() {
  local input_path="$1"

  if [[ -d "$input_path" ]]; then
    cd "$input_path" && pwd
    return
  fi

  if [[ -n "${BAS_DIR:-}" || -n "${WRK_DIR:-}" ]]; then
    local candidate="${BAS_DIR:-}${WRK_DIR:-}$input_path"
    if [[ -d "$candidate" ]]; then
      cd "$candidate" && pwd
      return
    fi
  fi

  return 1
}

# Validate number of arguments
if [[ $# -ne 1 ]]; then
  echo "UNCERTAIN: Invalid number of arguments - Usage: resize_webp_1600 folder"
  exit 1
fi

if ! command -v "${IM_IDENTIFY[0]}" >/dev/null 2>&1; then
  echo "UNCERTAIN: identify command not found"
  exit 1
fi

if ! command -v "${IM_CONVERT[0]}" >/dev/null 2>&1; then
  echo "UNCERTAIN: convert command not found"
  exit 1
fi

if ! TARGET_DIR="$(resolve_target_dir "$1")"; then
  echo "UNCERTAIN: Invalid argument: folder expected"
  exit 1
fi

cd "$TARGET_DIR"
pwd

res1=$(date +%s)
rename_count=0
skip_count=0

find ./ -maxdepth 2 -type f \( -iname '*.webp' \) -print0 | while IFS= read -r -d $'\0' file; do
  IMG="${file#./}"
  DIRNAME="$(dirname "$IMG")"
  BASENAME="$(basename -- "$IMG")"
  STEM="${BASENAME%.*}"
  EXT="${BASENAME##*.}"

  # 檔名主體含底線時，視為既有衍生檔，避免重複處理。
  if echo "$STEM" | grep -Eq '_'; then
    echo "skip [$IMG]: filename already contains underscore"
    continue
  fi

  WIDTH="$("${IM_IDENTIFY[@]}" -format '%w' "$IMG")"

  # 只處理寬度大於 1600 的大圖。
  if ! [[ "$WIDTH" =~ ^[0-9]+$ ]] || (( WIDTH <= TARGET_WIDTH )); then
    echo "skip [$IMG]: width=$WIDTH"
    continue
  fi

  ORI_NAME="${STEM}_ori.${EXT}"
  if [[ "." == "$DIRNAME" ]]; then
    ORI_PATH="$ORI_NAME"
  else
    ORI_PATH="$DIRNAME/$ORI_NAME"
  fi

  if [[ -e "$ORI_PATH" ]]; then
    echo "skip [$IMG]: original backup already exists as [$ORI_PATH]"
    continue
  fi

  mv -- "$IMG" "$ORI_PATH"
  "${IM_CONVERT[@]}" "$ORI_PATH" -quality 90 -resize "${TARGET_WIDTH}x" "$IMG"
  echo "done [$IMG]: renamed original to [$ORI_PATH] and created ${TARGET_WIDTH}px resize"
done

echo "DONE"
res2=$(date +%s)
dt=$((res2 - res1))

printf "Total runtime: %d sec.\n" "$dt"